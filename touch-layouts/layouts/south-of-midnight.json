              },
              {
                "type": "button",
                "action": "rightThumb"
              },
              {
                "type": "button",
                "action": "gamepadY",
                "styles": {
                  "default": {
                    "faceImage": {
                      "type": "icon",
                      "value": "interact"
                    }
                  }
                }
              }
            ],
            {
              "type": "button",
              "action": "leftTrigger"
            },
            {
              "type": "button",
              "action": "leftBumper"
            }
