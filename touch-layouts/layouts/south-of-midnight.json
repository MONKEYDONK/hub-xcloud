              "actionThreshold": 2,
              "styles": {
                "default": {
                  "knob": {
                    "faceImage": {
                      "type": "icon",
                      "value": "walk"
                    }
                  }
                },
                "activated": {
                  "knob": {
                    "faceImage": {
                      "type": "icon",
                      "value": "sprint"
                    }
                  }
                }
              }
            }
          ],
          "outer": [
            null,
            null,
            [
              {
                "type": "directionalPad"
              }
            ],
            null,
            null,
            null,
            null
          ]
        },
        "right": {
          "inner": [
            {
              "type": "joystick",
              "expand": false,
              "axis": {
                "input": "axisXY",
                "output": "rightJoystick"
