                  "default": {
                    "faceImage": {
                      "type": "icon",
                      "value": "jump"
                    }
                  }
                }
              }
            ],
            [
              {
                "type": "button",
                "action": "gamepadX",
                "styles": {
                  "default": {
                    "faceImage": {
                      "type": "icon",
