    "mgs2": {
      "name": "MGS 2",
      "author": "Kode-Z",
      "content": {
        "layers": {
          "rJoystick": {
            "right": {
              "inner": [
                {
                  "type": "joystick",
                  "axis": {
                    "input": "axisXY",
                    "output": "leftJoystick"
                  }
                }
              ]
            }
